{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/api/chat",     "destination": "/api/chat.js" },
    { "source": "/api/feedback", "destination": "/api/feedback.js" }
  ],
  "redirects": [
    { "source": "/advisor.html",        "destination": "/pages/ai_advisor.html",    "permanent": false },
    { "source": "/ai-advisor.html",     "destination": "/pages/ai_advisor.html",    "permanent": false },
    { "source": "/pricing.html",        "destination": "/pages/pricing.html",       "permanent": false },
    { "source": "/knowledge.html",      "destination": "/pages/knowledge_base.html","permanent": false },
    { "source": "/knowledge-base.html", "destination": "/pages/knowledge_base.html","permanent": false },
    { "source": "/system-design.html",  "destination": "/pages/system_design.html", "permanent": false },
    { "source": "/crane-diagnostic.html","destination": "/crane-diagnostic.html",   "permanent": false },
    { "source": "/privacy.html",        "destination": "/pages/privacy.html",       "permanent": false },
    { "source": "/disclaimer.html",     "destination": "/pages/disclaimer.html",    "permanent": false },
    { "source": "/feedback.html",       "destination": "/pages/pricing.html",       "permanent": false },
    { "source": "/news.html",           "destination": "/",                         "permanent": false },
    { "source": "/admin.html",          "destination": "/",                         "permanent": false },
    { "source": "/services.html",       "destination": "/",                         "permanent": false },
    { "source": "/about.html",          "destination": "/",                         "permanent": false },
    { "source": "/contact.html",        "destination": "/pages/pricing.html",       "permanent": false },
    { "source": "/pages/about.html",    "destination": "/",                         "permanent": false },
    { "source": "/pages/contact.html",  "destination": "/pages/pricing.html",       "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "Strict-Transport-Security","value": "max-age=31536000; includeSubDomains" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://hydromind-backend.onrender.com https://frqefpoheewbornozvhc.supabase.co; img-src 'self' data: https:; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800, immutable" }]
    }
  ]
}
