{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/api/chat",     "destination": "/api/chat.js" },
    { "source": "/api/feedback", "destination": "/api/feedback.js" }
  ],
  "redirects": [
    { "source": "/advisor.html",       "destination": "/pages/advisor.html",       "permanent": true },
    { "source": "/pricing.html",       "destination": "/pages/pricing.html",       "permanent": true },
    { "source": "/knowledge.html",     "destination": "/pages/knowledge.html",     "permanent": true },
    { "source": "/news.html",          "destination": "/pages/news.html",          "permanent": true },
    { "source": "/feedback.html",      "destination": "/pages/feedback.html",      "permanent": true },
    { "source": "/admin.html",         "destination": "/pages/admin.html",         "permanent": true },
    { "source": "/services.html",      "destination": "/pages/services.html",      "permanent": true },
    { "source": "/privacy.html",       "destination": "/pages/privacy.html",       "permanent": true },
    { "source": "/disclaimer.html",    "destination": "/pages/disclaimer.html",    "permanent": true },
    { "source": "/system-design.html", "destination": "/pages/system-design.html", "permanent": true },
    { "source": "/contact.html",       "destination": "/pages/pricing.html",       "permanent": true },
    { "source": "/about.html",         "destination": "/",                          "permanent": true },
    { "source": "/pages/contact.html", "destination": "/pages/pricing.html",       "permanent": true },
    { "source": "/pages/about.html",   "destination": "/",                          "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://hydromind-backend.onrender.com https://frqefpoheewbornozvhc.supabase.co; img-src 'self' data: https:; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
