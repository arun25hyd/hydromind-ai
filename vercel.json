{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/feedback", "destination": "/api/feedback.js" }
  ],
  "redirects": [
    { "source": "/", "destination": "/maintenance.html", "permanent": false },
    { "source": "/index.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/ai_advisor.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/crane_diagnostic.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/knowledge_base.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/system_design.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/pricing.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/feedback.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/disclaimer.html", "destination": "/maintenance.html", "permanent": false },
    { "source": "/pages/:path*", "destination": "/maintenance.html", "permanent": false },
    {
      "source": "/(.*)",
      "destination": "https://www.hydromindai.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "hydromindai.com"
        }
      ]
    },
    {
      "source": "/pages/ai_advisor.html",
      "destination": "/ai_advisor.html",
      "permanent": true
    },
    {
      "source": "/pages/crane_diagnostic.html",
      "destination": "/crane_diagnostic.html",
      "permanent": true
    },
    {
      "source": "/pages/system_design.html",
      "destination": "/system_design.html",
      "permanent": true
    },
    {
      "source": "/pages/knowledge_base.html",
      "destination": "/knowledge_base.html",
      "permanent": true
    },
    {
      "source": "/pages/pricing.html",
      "destination": "/pricing.html",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/pages/privacy.html",
      "permanent": true
    },
    {
      "source": "/pages/disclaimer.html",
      "destination": "/disclaimer.html",
      "permanent": true
    },
    {
      "source": "/pages/advisor.html",
      "destination": "/ai_advisor.html",
      "permanent": true
    },
    {
      "source": "/pages/hydromind.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/advisor",
      "destination": "/ai_advisor.html",
      "permanent": false
    },
    {
      "source": "/crane",
      "destination": "/crane_diagnostic.html",
      "permanent": false
    },
    {
      "source": "/system-design",
      "destination": "/system_design.html",
      "permanent": false
    },
    {
      "source": "/knowledge",
      "destination": "/knowledge_base.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://hydromind-backend.onrender.com https://frqefpoheewbornozvhc.supabase.co wss://frqefpoheewbornozvhc.supabase.co https://cdn.jsdelivr.net https://api.web3forms.com https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net; img-src 'self' data: https:; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; frame-ancestors 'none';"
        }
      ]
    }
  ]
}
