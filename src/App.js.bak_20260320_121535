  const tabs=[{id:"cylinder",l:"⚙ Cylinder"},{id:"pump",l:"⚙ Pump"},{id:"motor",l:"⚙ Motor"},{id:"pdrop",l:"⚙ Pressure Drop"},{id:"piping",l:"⚙ Piping"},{id:"elec",l:"⚡ Electrical",g:true}];
