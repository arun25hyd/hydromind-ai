      const T=(d>0&&p>0)?(d*p*(me/100))/(20*Math.PI):0,n=(d>0&&q>0)?(q*1000)/d:0,P=(p>0&&q>0)?(p*q)/600:0;
      r.mt=fmt(unit==="imp"?T*0.73756:T,1);r.mn=fmt(n,0);r.mp=fmt(unit==="imp"?P*1.34102:P,2);r.me=fmt(me,0);
    }else if(tab==="pdrop"){
